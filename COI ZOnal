        system_final.append(np.nan)
        system_damping.append(np.nan)
        system_recovery.append(np.nan)
        continue
    else:
        RMS_converge.append(int(1))
        app.PrintPlain("SUCESS! RMS SIMULATION CONVERGED!")

        #PART 3 GET RESULTS
    results.Load() #Loads results
    num_res = results.GetNumberOfRows() #get number of results
    app.PrintPlain("Number of result rows = " + str(num_res))
    gen_col_idx = {}
    
    #SYSTEM COI FREQ CALCULATION
    for gen in system_weights:
        gen_col_idx[gen] = results.FindColumn(gen, "n:fehz:bus1")
    
    system_coi = np.zeros(num_res)

    for i in range(num_res):
        num = 0.0
        den = 0.0
    
        for gen, weight in system_weights.items():
            idx = gen_col_idx[gen]
            if idx < 0:
                continue
            f = results.GetValue(i, idx)[1]
            if np.isnan(f):
                continue    
            num += weight * f
            den += weight
    
        system_coi[i] = num / den if den > 0 else np.nan
        
    # TOTAL SYSTEM INERTIA
    P_sync = 0.0
    P_total = 0.0
    num = 0.0
    den_sync = 0.0
    
    # synchronous machines
    for gen in syn_machines:
        if gen.outserv == 0 and gen.pgini > 0:
            P_sync += gen.pgini   
    
            H = gen.typ_id.h
            S = gen.typ_id.sgn
    
            num += H * S
            den_sync += S
    
    # total generation (sync + static)
    for gen in syn_machines:
        if gen.outserv == 0 and gen.pgini > 0:
            P_total += gen.pgini
    
    for gen in stat_machines:
        if gen.outserv == 0 and gen.pgini > 0:
            P_total += gen.pgini
    
    # Step 1: synchronous inertia
    H_sync = num / den_sync if den_sync != 0 else np.nan
    
    # Step 2: effective system inertia
    H_sys_eff = (P_sync / P_total) * H_sync if P_total != 0 else np.nan
    
    app.PrintPlain("System COI sample → " + str(system_coi[:5]))
        
    time_index = results.FindColumn("b:tnow")
    time = np.array([results.GetValue(i, time_index)[1] for i in range(num_res)], dtype=float)
    #Find the frequency columns inside ResFile
    freq = system_coi
    # NADIR
    nadir = np.min(freq)
    # ROCOF
    mask = (time >= 1.0) & (time <= 2.0)
    time_window = time[mask]
    freq_window = freq[mask]

    if len(time_window) > 1:
        dt = np.diff(time_window)
        df = np.diff(freq_window)
        rocof = df/dt
        min_rocof_value = np.min(rocof) if len(rocof) > 0 else np.nan
    else:
        min_rocof_value = np.nan

    # FINAL FREQUENCY
    final_freq = np.mean(freq[-3:])

    # OSCILLATIONS
    peaks, _ = fp(freq, distance=30, prominence=0.005)
    troughs, _ = fp(-freq, distance=30, prominence=0.005)

    extremes = np.sort(np.concatenate([peaks, troughs]))
    extreme_freq = freq[extremes]

    damping_ratio = np.nan
    stability = 1

    if len(extremes) > 4:
        extreme_freq = extreme_freq[2:]
        extreme_amp = np.abs(extreme_freq - final_freq)

        if len(extreme_amp) > 1:
            log_decrements = []
            for i in range(len(extreme_amp)-1):
                delta = np.log(extreme_amp[i] / (extreme_amp[i+1] + 1e-7))
                log_decrements.append(delta)

            delta_avg = np.mean(log_decrements)
            damping_ratio = delta_avg / np.sqrt((4*np.pi)**2 + delta_avg**2)

            if np.max(extreme_amp) < 0.02:
                stability = 1
            else:
                stability = 0

    # SETTLING TIME
    tol = 0.02
    settling_time = np.nan
    count = 0

    for i in range(len(freq)):
        if abs(freq[i] - final_freq) <= tol:
            count += 1
            if count > 3:
                settling_time = time[i]
        else:
            count = 0

    # STORE
    system_H_effective.append(H_sys_eff)
    system_coi_list.append(system_coi)
    system_nadir.append(nadir)
    system_rocof.append(min_rocof_value)
    system_final.append(final_freq)
    system_damping.append(damping_ratio)
    system_recovery.append(settling_time)
    
df_fitted_stable[" Effective Inertia "] = system_H_effective
