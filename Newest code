        #Calculate Peaks and troughs in frequency
        peaks, _ = fp(freq, distance = 30, prominence=0.005)
        troughs, _ = fp(-freq, distance = 30, prominence=0.005)
        
        extremes = np.sort(np.concatenate([peaks, troughs]))
        extreme_time = time[extremes]
        extreme_freq = freq[extremes]
        # --- FIRST SWING CLASSIFICATION ---
        extreme_amp_50 = np.abs(extreme_freq - 50)
        
        extreme_amp_50 = np.abs(extreme_freq - 50)

        if len(extreme_amp_50) >= 6:
            mid = len(extreme_amp_50) // 2

            early_average = np.mean(extreme_amp_50[:mid])
            late_average = np.mean(extreme_amp_50[mid:])

            if late_average < early_average * 0.98:
                response_type = "decaying"
            elif late_average > early_average * 1.02:
                response_type = "growing"
            else:
                response_type = "decaying"
        else:
            # not enough peaks → assume stable
            response_type = "decaying"
        

        if response_type == "decaying":
            ref = np.mean(freq[-5:])
            app.PrintPlain("Response: Decaying")
        else:
            ref = 50.0
            app.PrintPlain("Response: Growing")
        # default for final freqeuncy
        final_freq = np.mean(freq[-3:])
        
        #If oscillatory
        if len(extremes)>4:
            app.PrintPlain("Peaks are: " + str(extreme_freq))
            # Remove disturbance
            extreme_freq = extreme_freq[2:]
            extreme_time = extreme_time[2:]
        
            extreme_amp = np.abs(extreme_freq - ref)
            if len(extreme_amp) <= 1:
                stability = 1
                damping_ratio = np.nan
                small_signal = True
            if(len(extreme_amp)>1):
                if np.max(extreme_amp) < 0.02:
                    small_signal = True
                    stability = 1
                else:
                    small_signal = False
        
            # DAMPING
            if len(extreme_amp) >= 2:
                log_decrements = []
                for i in range(len(extreme_amp)-1):
                    delta = np.log(extreme_amp[i] / (extreme_amp[i+1] + 1e-7))
                    log_decrements.append(delta)
        
                delta_avg = np.mean(log_decrements)
                damping_ratio = delta_avg / np.sqrt((4*np.pi)**2 + delta_avg**2)
            else:
                damping_ratio = np.nan
        
            mid = len(extreme_amp) // 2
            early_average = np.mean(extreme_amp[:mid])
            late_average = np.mean(extreme_amp[mid:])
        
            # --- FINAL STABILITY ---
            if (small_signal==True):
                stability = 1
                damping_ratio = abs(damping_ratio)
            elif response_type == "growing":
                stability = 0
                damping_ratio = -abs(damping_ratio)
        
            elif response_type == "decaying":
                if (late_average*1.01 < early_average):
                    stability = 1
                else:
                    stability = 0
        
        elif len(extremes)<=4:
