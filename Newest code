            final_freq = np.mean(freq_tail)
            
            if len(freq_tail) > 1:
                slope = (freq_tail[-1]-freq_tail[0])/(time_tail[-1]- time_tail[0] + 1e-6)
            else:
                slope = 0
            
            if (variation < 0.05):
                stability = 1
            else:
                stability = 0
                
        app.PrintPlain("Stability is:                 " + str(stability))
